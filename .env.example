# Copy this file to `.env` and edit it for your machine.
# The worker stays local-only by default until you explicitly enable registration.

# Human-readable worker name used during `nexus-worker init`
NEXUS_WORKER_NAME=My Worker Node

# Optional stable worker ID. Leave blank to auto-generate.
NEXUS_WORKER_ID=

# Local worker bind settings
NEXUS_WORKER_HOST=0.0.0.0
NEXUS_WORKER_PORT=8010

# Local model discovery
OLLAMA_HOST=http://localhost:11434
VLLM_MODELS=

# Runtime output folder created by `nexus-worker init`
NEXUS_WORKER_OUTPUT_DIR=generated/worker-node

# Control-plane connection is opt-in
NEXUS_WORKER_AUTO_REGISTER=0
CONTROL_PLANE_URL=
CONTROL_PLANE_API_TOKEN=

# Runtime behavior
HEARTBEAT_INTERVAL=15
NEXUS_WORKER_CLOUD_CONTEXT_POLICY=redact
